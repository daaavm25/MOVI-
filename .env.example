# Server
NODE_ENV=development
PORT=8000
HOST=0.0.0.0
FRONTEND_URL=http://127.0.0.1:5500

# TMDB
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_PROVIDER_COUNTRY=MX

# Jackett
JACKETT_URL=http://localhost:9117
JACKETT_API_KEY=your_jackett_api_key_here

# Optional external API key for integrations
API_KEY_EXTERNA=your_external_api_key_here

# PostgreSQL (optional if using DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=movieplus
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Full URL alternative
# DATABASE_URL=postgres://user:password@localhost:5432/postgres
