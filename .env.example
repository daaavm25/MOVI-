# ════════════════════════════════════════════════════════════
#  MOVI- — Variables de entorno
#  Copia este archivo a .env y rellena los valores reales.
#  NUNCA subas .env a git.
# ════════════════════════════════════════════════════════════

# ── Entorno ─────────────────────────────────────────────────
NODE_ENV=production          # development | production

# ── Servidor ────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
# En producción pon la URL pública de tu VPS/dominio
FRONTEND_URL=https://TU_DOMINIO.com

# ── Administradores (separados por coma) ────────────────────
ADMIN_USERNAMES=admin

# ── TMDB (The Movie Database) ───────────────────────────────
# Obtén tu clave en https://www.themoviedb.org/settings/api
TMDB_API_KEY=PEGA_TU_CLAVE_TMDB_AQUI
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_PROVIDER_COUNTRY=MX

# ── PostgreSQL ───────────────────────────────────────────────
# Usa una contraseña segura (mínimo 20 caracteres aleatorios)
DB_HOST=db
DB_PORT=5432
DB_NAME=movieplus
DB_USER=postgres
DB_PASSWORD=CAMBIA_ESTO_POR_UNA_CONTRASENA_SEGURA

# Alternativa: URL completa (tiene prioridad sobre las variables anteriores)
# DATABASE_URL=postgres://postgres:PASSWORD@db:5432/movieplus

# ── Jackett (buscador de torrents) ──────────────────────────
JACKETT_URL=http://localhost:9117
JACKETT_API_KEY=PEGA_TU_API_KEY_JACKETT_AQUI
